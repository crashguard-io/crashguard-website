---
import '../styles/global.css'

interface Props {
  title?: string
}

const { title = 'CrashGuard.io — Canary-Oriented Workflow Monitoring' } = Astro.props
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-gray-950 text-gray-100 overflow-x-hidden">
    <slot />

    <div
      id="lightbox-overlay"
      class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 p-6 cursor-zoom-out"
    >
      <img id="lightbox-image" src="" alt="" class="max-h-full max-w-full rounded-lg shadow-2xl" />
    </div>

    <script>
      const overlay = document.getElementById('lightbox-overlay') as HTMLDivElement
      const overlayImg = document.getElementById('lightbox-image') as HTMLImageElement

      function openLightbox(src: string, alt: string) {
        overlayImg.src = src
        overlayImg.alt = alt
        overlay.classList.remove('hidden')
        overlay.classList.add('flex')
        document.body.classList.add('overflow-hidden')
      }

      function closeLightbox() {
        overlay.classList.add('hidden')
        overlay.classList.remove('flex')
        overlayImg.src = ''
        document.body.classList.remove('overflow-hidden')
      }

      document.querySelectorAll<HTMLImageElement>('img.lightbox-img').forEach((img) => {
        img.addEventListener('click', () => openLightbox(img.src, img.alt))
      })

      overlay.addEventListener('click', closeLightbox)
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeLightbox()
      })
    </script>
  </body>
</html>
